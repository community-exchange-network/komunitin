<!-- other expired posts -->
<tr>
  <td class="mobile-pad" style="padding: 0 30px 14px 30px;">
    {{#if otherPostsTitle}}
    <div style="font-size: 12px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: rgba(0,0,0,0.5); margin-bottom: 8px;">
      {{otherPostsTitle}}
    </div>
    {{/if}}
    <table width="100%" cellspacing="0" cellpadding="0" border="0" style="border: 1px solid #eeeeee; border-radius: 8px;">
      {{#each otherPosts}}
      <tr>
        <td style="padding: 12px 16px;{{#if @last}}{{else}} border-bottom: 1px solid #eeeeee;{{/if}}">
          <div style="color: {{accentColor}}; font-size: 10px; font-weight: 600; letter-spacing: 0.5px; margin-bottom: 6px; text-transform: uppercase;">
            {{typeLabel}}
          </div>
          <div style="font-size: 14px; line-height: 1.3; color: #333; font-weight: 600;">
            {{this.title}}
          </div>
          <div style="margin-top: 10px; font-size: 12px; color: #555; line-height: 1.4;">
            {{expiryLabel}}
          </div>
        </td>
      </tr>
      {{/each}}
    </table>
  </td>
</tr>
