    "@prisma/client": "7.8.0",
    "@smithy/fetch-http-handler": "^5.4.3",
    "cors": "^2.8.5",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "express-oauth2-jwt-bearer": "^1.8.0",
    "file-type": "^20.5.0",
    "formidable": "^3.5.4",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
