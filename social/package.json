    "@types/qs": "^6.9.18",
    "@types/supertest": "^6.0.3",
    "jose": "^6.2.3",
    "msw": "^2.14.3",
    "pino-pretty": "^10.3.0",
    "prisma": "7.8.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "unbuild": "^3.6.1"
