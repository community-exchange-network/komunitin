  "description": "Komunitin Social Service (Node.js/TypeScript)",
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch --inspect=0.0.0.0:9229 src/index.ts",
    "build": "pnpm typecheck && unbuild",
    "start": "node dist/index.mjs",
    "test": "node --experimental-test-module-mocks --env-file=.env.test --import tsx --test-concurrency=1 --test ./**/*.test.ts",
    "test-one": "node --experimental-test-module-mocks --env-file=.env.test --import tsx --test-concurrency=1 --test"
  },
  "keywords": [],
