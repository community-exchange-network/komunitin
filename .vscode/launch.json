{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Notifications service",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "port": 40000,
      "host": "localhost",
      "remotePath": "/opt/notifications",
      "cwd": "${workspaceRoot}/notifications",
      "dlvLoadConfig": {
        "followPointers": true,
        "maxStringLen": 256,
        "maxArrayValues": 64,
        "maxStructFields": -1
      }
    },
    // Node inspect ports mirror service HTTP ports: 2023 -> 9223, 2025 -> 9225, 2026 -> 9226, 2028 -> 9228.
    {
      "name": "Notifications TS service",
      "type": "node",
      "request": "attach",
      "port": 9223,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/notifications-ts",
      "remoteRoot": "/app",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Accounting service",
      "type": "node",
      "request": "attach",
      "port": 9225,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/accounting",
      "remoteRoot": "/app",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Auth service",
      "type": "node",
      "request": "attach",
      "port": 9226,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/auth",
      "remoteRoot": "/app",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Social service",
      "type": "node",
      "request": "attach",
      "port": 9228,
      "address": "localhost",
      "localRoot": "${workspaceFolder}/social",
      "remoteRoot": "/app",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Launch Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:2030",
      "webRoot": "${workspaceFolder}/app",
      "userDataDir": "${workspaceFolder}/.vscode/chrome",
    }
    
  ]
}
